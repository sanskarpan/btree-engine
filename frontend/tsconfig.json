{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "lib": ["ES2022", "DOM"],
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*", "server/**/*"],
  "exclude": ["node_modules", "dist", "server/**/*.test.ts", "e2e/**/*", "playwright.config.ts", "scripts/**/*"]
}
